{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest --environment happy-dom --exclude tests/e2e/**",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:ci": "playwright test --reporter=github"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "element-plus": "^2.9.3",
    "pinia": "^2.2.6",
    "vue": "^3.5.18",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "happy-dom": "^18.0.1",
    "typescript": "~5.8.3",
    "vite": "^5.4.10",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.5"
  }
}
